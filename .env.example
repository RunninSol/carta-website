# ─────────────────────────────────────────────────────────────
# Carta website — environment variables
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── A. CALENDLY (booking) ───────────────────────────────────
# Your PUBLIC Calendly scheduling link. No API key / OAuth needed.
# Create an event type in Calendly (e.g. "Discovery Call") and paste
# its share link here. Exposed to the browser, so it must be public.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/travelbycarta/discovery-call

# ── B. INQUIRY FORM (email via Gmail SMTP / Nodemailer) ─────
# Uses your existing Google Workspace inbox. To get SMTP_PASS:
#   1. Google Account → Security → 2-Step Verification (must be ON)
#   2. Security → App passwords → create one named "Carta Website"
#   3. Paste the 16-character app password below (NOT your login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=gabe@travelbycarta.com
SMTP_PASS=your-16-char-google-app-password

# Where inquiries are delivered, and the From header shown in your inbox.
CONTACT_TO=gabe@travelbycarta.com
CONTACT_FROM=Carta Website <gabe@travelbycarta.com>
